module.exports.config = {
    name:        "demo",               // command এর নাম (lowercase)
    version:     "1.0.0",              // version নম্বর
    credit:      "MOHAMMAD BADOL",     // ⚠️ এটা change করলে command load হবে না
    role:        0,                    // 0 = সবাই, 1 = শুধু Admin/Owner
    description: "এটি একটি demo command", // command কী করে তার বর্ণনা
    prefix:      true,                 // true = prefix দিতে হবে, false = prefix ছাড়া
    aliases:     ["dmo", "test"],      // alternative নাম (optional)
