};

// ─── onStartBadol ────────────────────────────────────────────
// কমান্ড রান হলে এটা execute হয়
// পুরনো নাম ছিল: onStart — এখন onStartBadol
module.exports.onStartBadol = async function (api, event, args) {
    const { threadID, messageID, senderID } = event;

    // args = command এর পরে যা লেখা হয়েছে (array)
    // যেমন: /demo hello world → args = ["hello", "world"]
    if (!args[0]) {
        return api.sendMessage(
            "╭─❏ DEMO COMMAND\n" +
            "│ ব্যবহার: /demo [text]\n" +
            "│ উদাহরণ: /demo hello\n" +
            "╰──────────────",
            threadID, messageID
        );
    }

    const text = args.join(" ");

    // reply করার সময় messageID দিলে সেই message এর reply যায়
    const sentInfo = await api.sendMessage(
        `✅ তুমি বললে: ${text}\n` +
        `📍 Thread: ${threadID}\n` +
        `👤 User: ${senderID}`,
        threadID, messageID
    );

    // onReplyBadol এর জন্য cache এ save করো
    if (sentInfo && sentInfo.messageID) {
        global.msgCache.set(sentInfo.messageID, {
            body:        text,
            senderID:    senderID,
            attachments: [],
            commandName: module.exports.config.name
        });
    }
};

// ─── onReplyBadol ────────────────────────────────────────────
// bot এর message এ reply করলে এটা execute হয়
// পুরনো নাম ছিল: onReply
module.exports.onReplyBadol = async function (api, event, cache) {
    const { threadID, messageID, body } = event;

    // cache = আগে পাঠানো message এর info
    if (!cache || cache.commandName !== module.exports.config.name) return;

    return api.sendMessage(
        `🔄 তুমি reply করলে: ${body}`,
        threadID, messageID
    );
};

